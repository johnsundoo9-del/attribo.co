# Attribo — Netlify security configuration
# Applies hardened HTTP security headers to every page.

[[headers]]
  for = "/*"
  [headers.values]
    # Stop other sites from framing yours (clickjacking protection)
    X-Frame-Options = "SAMEORIGIN"
    # Stop browsers from guessing file types (MIME-sniffing protection)
    X-Content-Type-Options = "nosniff"
    # Don't leak full URLs to other sites
    Referrer-Policy = "strict-origin-when-cross-origin"
    # Force HTTPS for 1 year, including subdomains
    Strict-Transport-Security = "max-age=31536000; includeSubDomains; preload"
    # Turn off browser features you don't use
    Permissions-Policy = "geolocation=(), microphone=(), camera=(), payment=()"
    # Only allow scripts/styles from you plus Google (blocks injected/malicious code)
    Content-Security-Policy = "default-src 'self'; base-uri 'self'; object-src 'none'; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://analytics.google.com; form-action 'self'"
